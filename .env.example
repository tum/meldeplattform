APP_NAME="TUM SafeSignal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=de
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meldeplattform
DB_USERNAME=meldeplattform
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Session hardening. Override SESSION_SECURE_COOKIE=true in production (HTTPS).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

MAIL_MAILER=smtp
MAIL_HOST=smtp.tum.de
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="meldeplattform@tum.de"
MAIL_FROM_NAME="${APP_NAME}"

# SAML2 Identity Provider settings
SAML2_IDP_ENTITYID=https://tumidp.lrz.de/idp/shibboleth
SAML2_IDP_METADATA_URL=https://login.tum.de/idp/shibboleth
SAML2_IDP_SSO_URL=https://login.tum.de/idp/profile/SAML2/Redirect/SSO
SAML2_IDP_SLO_URL=https://login.tum.de/idp/profile/Logout
SAML2_SP_ENTITYID="${APP_URL}/shib"
SAML2_SP_X509CERT=
SAML2_SP_PRIVATEKEY=
# PEM-encoded IdP signing certificate (body only, no BEGIN/END markers).
# REQUIRED in production. Without it the SP refuses to boot, because
# onelogin/php-saml would otherwise accept unsigned SAML responses.
SAML2_IDP_X509CERT=
SAML2_LOGOUT_URL="${APP_URL}"
SAML2_LOGIN_URL="${APP_URL}"

# Comma-separated list of SAML UIDs that have global admin rights.
MELDE_ADMIN_USERS=
# Max upload size in MB.
MELDE_MAX_UPLOAD_MB=10

# Dev login bypass. Must be explicitly enabled AND APP_ENV must not be
# "production". Leave unset / false in production deployments.
MELDE_DEV_LOGIN_ENABLED=false
